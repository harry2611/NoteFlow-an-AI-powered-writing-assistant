APP_PORT=80

POSTGRES_DB=noteflow
POSTGRES_USER=noteflow
POSTGRES_PASSWORD=replace-with-a-long-random-password

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

